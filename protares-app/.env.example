# ============================================================
# ProtaRes — Client environment variables (Expo)
# Copy to .env.development / .env.staging / .env.production
# NEVER commit real secrets to git.
# ============================================================

# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Google OAuth (Section 4 of master instructions)
# Create THREE OAuth clients in Google Cloud Console: Web, Android, iOS.
# webClientId = WEB client ID (even on Android — this is what signs id tokens)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=xxxx.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=xxxx.apps.googleusercontent.com
# iOS URL Scheme = reversed iOS client ID. Without this, iOS crashes on tap.
EXPO_PUBLIC_GOOGLE_IOS_URL_SCHEME=com.googleusercontent.apps.xxxx

# Google Maps (enable Maps SDK for both iOS AND Android in Google Cloud Console)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# App
EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_API_URL=https://api.protares.com

# Sentry
EXPO_PUBLIC_SENTRY_DSN=

# Feature Flags
EXPO_PUBLIC_ENABLE_WITNESS_MODE=true
EXPO_PUBLIC_ENABLE_SMS_FALLBACK=true

# EAS
EAS_PROJECT_ID=your-eas-project-id
